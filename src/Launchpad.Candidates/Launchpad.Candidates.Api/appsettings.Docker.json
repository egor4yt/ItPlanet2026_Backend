{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Launchpad": "Debug"
      }
    },
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "ConnectionStrings": {
    "SqlDatabase": "Host=database;Port=5432;Database=launchpad_candidates;Username=admin;Password=admin;SSL Mode=Disable;Include Error Detail=true;"
  },
  "SwaggerDocOptions": {
    "Title": "Launchpad Candidates API (Docker)",
    "Description": "Launchpad is an open-source career aggregator.",
    "Organization": "Ermakov Egor",
    "Email": "egor4yt@gmail.com"
  },
  "CorsOrigins": "http://localhost:3000",
  "Keycloak": {
    "BaseUrl": "http://localhost:1200",
    "Realm": "Launchpad",
    "Client": "frontend"
  }
}
